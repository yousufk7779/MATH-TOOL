{
  "expo": {
    "name": "Learn Smart 10",
    "slug": "jiguu-math-solutions",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "jiguu-solutions",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jiguu.mathsolutions"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1A",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jiguu.mathsolutions"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B0F1A",
          "light": {
            "backgroundColor": "#0B0F1A"
          },
          "dark": {
            "backgroundColor": "#0B0F1A"
          }
        }
      ],
      "expo-web-browser",
      "expo-asset"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
