{
  "expo": {
    "name": "Learn Smart 10",
    "slug": "jiguu-math-solutions",
    "version": "1.0.7",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "jiguu-solutions",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jiguu.mathtool"
    },
    "android": {
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1A",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jiguu.mathtool"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-asset"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "115d4047-b7ae-4d07-9c98-6d4a09fff8ab"
      }
    },
    "owner": "sameerk1379"
  }
}